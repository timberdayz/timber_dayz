# 西红ERP系统环境配置文件示例
# 复制此文件为 .env 并根据需要修改配置

# ================================
# 项目路径配置
# ================================
# 项目根目录（可选，系统会自动检测）
# XIHONG_ERP_ROOT=F:\Vscode\python_programme\xihong_erp

# ================================
# 调试配置
# ================================
# 启用调试模式（显示详细路径信息）
XIHONG_ERP_DEBUG=false

# ================================
# 数据库配置
# ================================
# 数据库文件名（相对于data目录）
DATABASE_NAME=sales_analytics.db

# ================================
# Web界面配置
# ================================
# Streamlit端口
STREAMLIT_PORT=8506

# ================================
# 数据处理配置
# ================================
# 自动处理间隔（秒）
AUTO_PROCESS_INTERVAL=1800

# 文件监控目录
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_ARCHIVE_DIR=data/archive

# ================================
# 日志配置
# ================================
# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 日志文件路径
LOG_FILE=logs/xihong_erp.log

# ================================
# 部署角色（本地与云端区分）
# ================================
# ENABLE_COLLECTION: 是否启用采集调度器。本地/采集环境=true，云端=false
# DEPLOYMENT_ROLE: 部署角色。local=本地（负责采集），cloud=云端（仅看板/报表）
# 本机采集测试使用 run.py --use-docker --collection 时由 docker-compose.collection-dev.yml 注入 ENABLE_COLLECTION=true
# ENABLE_COLLECTION=true
# DEPLOYMENT_ROLE=local
# ================================
# PostgreSQL Dashboard ????
# ================================
# false: ???? Dashboard ??
# true: ???? PostgreSQL Dashboard ??
USE_POSTGRESQL_DASHBOARD_ROUTER=false

