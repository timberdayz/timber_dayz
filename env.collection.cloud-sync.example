# Windows collection-machine example for Docker Desktop + backend-collector only.
# Copy values into your local .env or a dedicated override file before starting the collector.

ENVIRONMENT=development
APP_ENV=development
DEBUG=true

POSTGRES_USER=erp_user
POSTGRES_PASSWORD=erp_pass_2025
POSTGRES_DB=xihong_erp
REDIS_PASSWORD=redis_pass_2025

# Local business database used by the collector container.
DATABASE_URL=postgresql://erp_user:erp_pass_2025@localhost:15432/xihong_erp

# Formal collector role settings.
DEPLOYMENT_ROLE=collector
APP_RUNTIME_MODE=collector
ENABLE_COLLECTION=true

# Cloud sync runtime settings.
CLOUD_SYNC_WORKER_ENABLED=true
CLOUD_SYNC_WORKER_ID=cloud-sync-worker-1
CLOUD_SYNC_POLL_INTERVAL_SECONDS=5

# Remote cloud PostgreSQL, reached through the host-managed SSH tunnel.
# Use host.docker.internal from inside the collector container.
CLOUD_DATABASE_URL=postgresql://erp_user:YOUR_URLENCODED_PASSWORD@host.docker.internal:15433/xihong_erp

# SSH tunnel health settings.
CLOUD_SYNC_TUNNEL_ENABLED=true
CLOUD_SYNC_TUNNEL_HOST=host.docker.internal
CLOUD_SYNC_TUNNEL_PORT=15433

# Optional collector runtime settings.
DATABASE_ECHO=false
LOG_LEVEL=INFO
ALLOWED_HOSTS=localhost,127.0.0.1
