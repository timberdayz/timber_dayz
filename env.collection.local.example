# Local-only collection takeover overlay for a Windows development machine.
# Copy to .env.collection.local when this machine temporarily takes over
# collection + sync + cloud sync responsibilities.

ENVIRONMENT=development
APP_ENV=development
DEPLOYMENT_ROLE=local
APP_RUNTIME_MODE=collector
ENABLE_COLLECTION=true

REDIS_PORT=16379
REDIS_URL=redis://:redis_pass_2025@localhost:16379/0
CELERY_BROKER_URL=redis://:redis_pass_2025@localhost:16379/0
CELERY_RESULT_BACKEND=redis://:redis_pass_2025@localhost:16379/0

CLOUD_SYNC_WORKER_ENABLED=true
CLOUD_SYNC_WORKER_ID=cloud-sync-worker-1
CLOUD_SYNC_POLL_INTERVAL_SECONDS=5
CLOUD_DATABASE_URL=postgresql://erp_user:YOUR_URLENCODED_PASSWORD@127.0.0.1:15433/xihong_erp

CLOUD_SYNC_TUNNEL_ENABLED=true
CLOUD_SYNC_TUNNEL_HOST=127.0.0.1
CLOUD_SYNC_TUNNEL_PORT=15433

# Formal headed collection can auto-start the SSH tunnel before startup.
# Use key-based, non-interactive SSH login. Do not store passwords here.
CLOUD_SYNC_SSH_HOST=134.175.222.171
CLOUD_SYNC_SSH_USER=deploy
CLOUD_SYNC_SSH_KEY=C:\Users\18689\.ssh\github_actions_deploy
CLOUD_SYNC_REMOTE_DB_HOST=127.0.0.1
CLOUD_SYNC_REMOTE_DB_PORT=5432
